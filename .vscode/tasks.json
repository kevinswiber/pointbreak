{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build VS Code extension",
      "type": "npm",
      "script": "watch",
      "path": "extensions/vscode",
      "isBackground": true,
      "problemMatcher": {
        "owner": "esbuild",
        "pattern": {
          "regexp": "^✘ \\[ERROR\\] (.*)$",
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^\\[watch\\] build started$",
          "endsPattern": "^\\[watch\\] build finished$"
        }
      }
    }
  ]
}
